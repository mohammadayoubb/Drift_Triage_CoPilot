# Application environment
APP_ENV=local

# PostgreSQL — for LangGraph agent checkpoints
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/drift_triage

# Redis — for async job queue
REDIS_URL=redis://redis:6379/0

# MLflow
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_MODEL_NAME=bank-marketing-classifier

# Model artifacts (pipeline-generated — single source of truth)
MODEL_PATH=artifacts/models/bank_marketing_pipeline.joblib
METADATA_PATH=artifacts/reports/threshold.json

# Drift detection
REFERENCE_STATS_PATH=data/reference/reference_stats.json
DRIFT_WINDOW_SIZE=100

# Service URLs
AGENT_WEBHOOK_URL=http://agent:8001/webhooks/drift
MODEL_SERVICE_URL=http://model-service:8000

# LangGraph checkpointer: "memory" for local dev, "postgres" for production
AGENT_CHECKPOINTER=memory

# ML training
RECALL_TARGET=0.75
RANDOM_STATE=42

# ── LLM API Keys ──────────────────────────────────────────────
# OPENAI_API_KEY powers the agent's triage analysis and investigation
# summaries (model: gpt-4o-mini). Required for real LLM calls in
# the running stack. CI uses mocks — no key needed there.
# Do NOT commit a real key to git.
OPENAI_API_KEY=sk-...your-key-here
